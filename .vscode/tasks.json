{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "STM32: Configure FindLine Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/A/STM32/FindLine"
            },
            "problemMatcher": []
        },
        {
            "label": "STM32: Build FindLine Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "Debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/A/STM32/FindLine"
            },
            "dependsOn": "STM32: Configure FindLine Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
